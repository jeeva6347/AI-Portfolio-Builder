# Copy to .env and fill in real values. Never commit .env.
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# DB_ENGINE=mysql to use MySQL, otherwise sqlite is used automatically
DB_ENGINE=sqlite
DB_NAME=aiportfoliobuilder
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

ACCOUNT_EMAIL_VERIFICATION=optional

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Email (password reset, email verification). Defaults to console backend
# (prints emails to the terminal) if left blank.
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@aiportfoliobuilder.com

# Remember Me session length, in seconds (default 14 days)
SESSION_COOKIE_AGE=1209600
